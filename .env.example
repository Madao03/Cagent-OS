# ── LLM Provider ──
# openrouter | deepseek | openai | anthropic | groq | siliconflow | together | custom
LLM_PROVIDER=openrouter

# ── Provider-specific API Keys (at least one required) ──
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Generic API key (fallback for any provider when specific key not set) ──
LLM_API_KEY=

# ── Custom endpoint (required when LLM_PROVIDER=custom) ──
LLM_BASE_URL=

# ── Model aliases (task → model mapping, JSON format) ──
DEFAULT_MODEL_ALIAS=claude-balanced
# MODEL_ALIASES='{"claude-balanced":"deepseek-chat","deepseek-strong":"deepseek-reasoner"}'

# ── LLM proxy (dev environment in China) ──
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# ── Database paths (SQLite) ──
SQLITE_DATA_DIR=./data
CONVERSATION_DB_PATH=./data/conversations.db
MEMORY_DB_PATH=./data/memory.db
TRACE_DB_PATH=./data/trace.db

# ── MCP Servers ──
MCP_SERVERS_CONFIG=./config/mcp_servers.json

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
